# Database (choose one PostgreSQL provider)
# Supabase Vercel/runtime example (recommended):
# Use the Session Pooler URI from Supabase because it is IPv4-compatible.
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@[REGION].pooler.supabase.com:5432/postgres"
#
# Supabase direct connection example (for Prisma migrate/db push):
# DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
#
# Neon example:
# DATABASE_URL="postgresql://[USER]:[PASSWORD]@[ENDPOINT].neon.tech/[DB]?sslmode=require"
DATABASE_URL=""
DIRECT_URL=""

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-to-a-long-random-secret"
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Default admin seed user
ADMIN_EMAIL="admin@jdigital.local"
ADMIN_PASSWORD="JDigital@12345"

# Email notifications
RESEND_API_KEY=""
RESEND_FROM_EMAIL="J-Digital Leads <onboarding@resend.dev>"
NOTIFY_TO_EMAIL="jdigitalsolutions27@gmail.com"

# SMTP
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL=""
